rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // ─── Users ───
    // Users can only read/write their own profile
    // Cloud Functions (admin SDK) bypass these rules
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // Use Cloud Functions for account deletion
    }

    // ─── AI Profiles ───
    // Users can read/write their own AI profile
    match /aiProfiles/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // ─── Prayer Logs ───
    // Users can read/write only their own prayer logs
    match /prayerLogs/{logId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
      // Allow list queries filtered by uid
      allow list: if isAuthenticated()
                  && request.query.constraints[0].field == 'uid'
                  && request.query.constraints[0].value == request.auth.uid;
    }

    // ─── Sahaba Progress ───
    // Users can read/write their own sahaba lesson progress
    match /sahabaProgress/{progressId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
      allow list: if isAuthenticated()
                  && request.query.constraints[0].field == 'uid'
                  && request.query.constraints[0].value == request.auth.uid;
    }

    // ─── Tasbih Sessions ───
    // Users can read/write their own tasbih sessions
    match /tasbihSessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
      allow list: if isAuthenticated()
                  && request.query.constraints[0].field == 'uid'
                  && request.query.constraints[0].value == request.auth.uid;
    }

    // ─── FCM Tokens ───
    // Users can register/update their own FCM token
    match /fcmTokens/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // ─── Weekly Reports ───
    // Users can read only their own weekly reports
    match /weeklyReports/{reportId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if false; // Only Cloud Functions write reports
      allow list: if isAuthenticated()
                  && request.query.constraints[0].field == 'uid'
                  && request.query.constraints[0].value == request.auth.uid;
    }

    // ─── Default: Deny All ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
